NODE_ENV=development
PORT=3001
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password
PG_DATABASE=realtimechat
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=15m
FRONTEND_ORIGIN=http://localhost:5177

# Firebase Admin (pick one approach)
# 1) Use service account JSON file path (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=C:/path/to/firebase-service-account.json

# 2) Or provide these three values directly
# FIREBASE_PROJECT_ID=realtimechat-e0016
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@realtimechat-e0016.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
